rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Öffentliche Lesezugriffe, Schreibzugriffe nur für Auth-User
    match /players/{id} { allow read: if true; allow write: if request.auth != null; }
    match /matches/{id} { allow read: if true; allow write: if request.auth != null; }
    match /events/{id}  { allow read: if true; allow write: if request.auth != null; }
    match /sponsors/{id}{ allow read: if true; allow write: if request.auth != null; }

    // Users-Collection: nur Admins dürfen schreiben
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.role == 'admin';
    }
  }
}